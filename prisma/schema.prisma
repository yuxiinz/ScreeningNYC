// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

model Movie {
  id              Int        @id @default(autoincrement())
  tmdbId          Int?       @unique 
  title           String     
  originalTitle   String?
  releaseDate     DateTime?
  runtimeMinutes  Int?
  overview        String?
  posterUrl       String?
  backdropUrl     String?
  

  imdbUrl         String?
  doubanUrl       String?
  letterboxdUrl   String?
  officialSiteUrl String?


  genresText      String?
  directorText    String?
  castText        String?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  showtimes       Showtime[]

  @@index([title]) 
}

model Theater {
  id              Int        @id @default(autoincrement())
  name            String
  slug            String    @unique 
  
  sourceName      String?    
  sourceTheaterId String?    @unique 
  
  address         String?

  latitude        Decimal?   @db.Decimal(10, 8)
  longitude       Decimal?   @db.Decimal(11, 8)
  
  borough         String?    
  officialSiteUrl String?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  showtimes       Showtime[]
}

model Format {
  id        Int        @id @default(autoincrement())
  name      String     @unique // "35mm", "70mm", "Digital", "IMAX"
  showtimes Showtime[]
}

model Showtime {
  id               Int            @id @default(autoincrement())
  movieId          Int
  theaterId        Int
  formatId         Int?

  startTime        DateTime
  endTime          DateTime?
  runtimeMinutes   Int?
  ticketUrl        String?

  sourceName       String?
  sourceUrl        String?
  sourceShowtimeId String?

  fingerprint      String?        @unique

  status           ShowtimeStatus @default(SCHEDULED)
  lastVerifiedAt   DateTime?

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  movie            Movie          @relation(fields: [movieId], references: [id], onDelete: Cascade)
  theater          Theater        @relation(fields: [theaterId], references: [id], onDelete: Cascade)
  format           Format?        @relation(fields: [formatId], references: [id])

  @@index([startTime])
  @@index([theaterId, startTime])
}

enum ShowtimeStatus {
  SCHEDULED
  CANCELED
  COMPLETED
}