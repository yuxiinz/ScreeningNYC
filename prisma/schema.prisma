// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

model Movie {
  id              Int        @id @default(autoincrement())
  tmdbId          Int?       @unique // 核心：以此作为 TMDB 的对齐标准
  title           String     // 不再唯一，允许同名电影
  originalTitle   String?
  releaseDate     DateTime?
  runtimeMinutes  Int?
  overview        String?
  posterUrl       String?
  backdropUrl     String?
  
  // 社交/专业平台链接
  imdbUrl         String?
  doubanUrl       String?
  letterboxdUrl   String?
  officialSiteUrl String?

  // 聚合文本，方便展示
  genresText      String?
  directorText    String?
  castText        String?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  showtimes       Showtime[]

  @@index([title]) // 优化按标题搜索的速度
}

model Theater {
  id              Int        @id @default(autoincrement())
  name            String
  slug            String?    @unique // 用于 URL: /map?theater=metrograph
  
  // 来源追踪
  sourceName      String?    // 例如 "metrograph", "film-forum"
  sourceTheaterId String?    @unique // 爬虫抓到的原始 ID
  
  address         String?
  // 经纬度改为可空，初期抓不到坐标不影响入库
  latitude        Decimal?   @db.Decimal(10, 8)
  longitude       Decimal?   @db.Decimal(11, 8)
  
  borough         String?    // 曼哈顿、布鲁克林等
  officialSiteUrl String?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  showtimes       Showtime[]
}

model Format {
  id        Int        @id @default(autoincrement())
  name      String     @unique // "35mm", "70mm", "Digital", "IMAX"
  showtimes Showtime[]
}

model Showtime {
  id               Int            @id @default(autoincrement())
  movieId          Int
  theaterId        Int
  formatId         Int?

  startTime        DateTime
  endTime          DateTime?
  runtimeMinutes   Int?
  ticketUrl        String?

  sourceName       String?
  sourceUrl        String?
  sourceShowtimeId String?

  fingerprint      String?        @unique

  status           ShowtimeStatus @default(SCHEDULED)
  lastVerifiedAt   DateTime?

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  movie            Movie          @relation(fields: [movieId], references: [id], onDelete: Cascade)
  theater          Theater        @relation(fields: [theaterId], references: [id], onDelete: Cascade)
  format           Format?        @relation(fields: [formatId], references: [id])

  @@index([startTime])
  @@index([theaterId, startTime])
}

enum ShowtimeStatus {
  SCHEDULED
  CANCELED
  COMPLETED
}